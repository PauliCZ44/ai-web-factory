---
import type { SiteConfig } from '@/content/site';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---
<section id="contact" class="bg-base-100">
  <div class="section-shell grid gap-10 lg:grid-cols-[0.85fr_1.15fr]">
    <div class="reveal" data-reveal>
      <p class="section-kicker">{site.contact.eyebrow}</p>
      <h2 class="mt-4 text-4xl font-bold leading-tight sm:text-5xl">{site.contact.title}</h2>
      <p class="mt-5 leading-8 text-base-content/72">{site.contact.text}</p>
    </div>
    <div class="reveal grid gap-4 sm:grid-cols-2" data-reveal>
      <a class="border border-base-300 p-6 transition hover:border-primary hover:bg-base-200/70" href={`tel:${site.phone.replaceAll(' ', '')}`}>
        <span class="text-sm font-bold uppercase tracking-[0.16em] text-primary">Telefon</span>
        <strong class="mt-3 block text-2xl">{site.phone}</strong>
      </a>
      <a class="border border-base-300 p-6 transition hover:border-primary hover:bg-base-200/70" href={`mailto:${site.email}`}>
        <span class="text-sm font-bold uppercase tracking-[0.16em] text-primary">Email</span>
        <strong class="mt-3 block break-words text-2xl">{site.email}</strong>
      </a>
      <div class="border border-base-300 p-6 sm:col-span-2">
        <span class="text-sm font-bold uppercase tracking-[0.16em] text-primary">Oblast</span>
        <strong class="mt-3 block text-2xl">{site.address}</strong>
      </div>
    </div>
  </div>
</section>
