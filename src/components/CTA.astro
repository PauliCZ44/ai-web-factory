---
import type { SiteConfig } from '@/content/site';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---
<section class="overflow-hidden bg-primary text-primary-content">
  <div class="section-shell relative grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
    <div class="absolute -right-8 top-8 hidden text-8xl font-black leading-none text-primary-content/10 md:block">AWF</div>
    <div class="reveal" data-reveal>
      <h2 class="text-4xl font-bold leading-tight sm:text-5xl">{site.cta.title}</h2>
      <p class="mt-4 max-w-2xl text-lg leading-8 text-primary-content/78">{site.cta.text}</p>
    </div>
    <a class="btn btn-secondary btn-lg reveal" href={`mailto:${site.email}`} data-reveal>{site.cta.action}</a>
  </div>
</section>
