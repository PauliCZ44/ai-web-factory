---
import type { SiteConfig } from '@/content/site';

interface Props {
  testimonials: SiteConfig['testimonials'];
}

const { testimonials } = Astro.props;
---
<section id="testimonials" class="bg-base-100">
  <div class="section-shell">
    <div class="reveal grid gap-5 md:grid-cols-[0.8fr_1fr] md:items-end" data-reveal>
      <div>
        <p class="section-kicker">{testimonials.eyebrow}</p>
        <h2 class="mt-4 text-4xl font-bold leading-tight sm:text-5xl">{testimonials.title}</h2>
      </div>
      <p class="max-w-2xl text-lg leading-8 text-base-content/70">{testimonials.text}</p>
    </div>

    <div class="mt-10 grid gap-4 lg:grid-cols-3">
      {testimonials.items.map((item, index) => (
        <figure class="testimonial-card reveal border border-base-300 bg-base-100 p-6 shadow-sm" data-reveal style={`transition-delay:${index * 90}ms`}>
          <blockquote class="text-xl font-semibold leading-8 text-base-content">
            &ldquo;{item.quote}&rdquo;
          </blockquote>
          <figcaption class="mt-8 border-t border-base-300 pt-4">
            <strong class="block text-lg">{item.name}</strong>
            <span class="text-sm font-bold uppercase tracking-[0.16em] text-primary">{item.role}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>