---
import type { SiteConfig } from '@/content/site';

interface Props {
  gallery: SiteConfig['gallery'];
}

const { gallery } = Astro.props;
---
<section id="gallery" class="factory-grid bg-base-200/70">
  <div class="section-shell">
    <div class="reveal flex flex-col gap-4 md:flex-row md:items-end md:justify-between" data-reveal>
      <div>
        <p class="section-kicker">{gallery.eyebrow}</p>
        <h2 class="mt-4 text-4xl font-bold leading-tight sm:text-5xl">{gallery.title}</h2>
      </div>
      <p class="max-w-md leading-7 text-base-content/70">
        {gallery.text}
      </p>
    </div>
    <div class="mt-10 grid gap-4 md:grid-cols-[1.2fr_0.9fr_1fr]">
      {gallery.images.map((image, index) => (
        <figure class:list={['reveal group overflow-hidden bg-base-100 shadow-md', index === 1 && 'md:translate-y-10', index === 0 && 'md:row-span-2']} data-reveal>
          <img class:list={['w-full object-cover transition duration-700 group-hover:scale-105', index === 0 ? 'h-[28rem] md:h-full' : 'h-72']} src={image.src} alt={image.alt} loading="lazy" />
        </figure>
      ))}
    </div>
  </div>
</section>
