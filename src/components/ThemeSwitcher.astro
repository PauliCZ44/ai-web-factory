---
import type { SiteConfig } from '@/content/site';

interface Props {
  site: SiteConfig;
}

const { site } = Astro.props;
---
<aside class="fixed bottom-4 right-4 z-50 w-[min(17rem,calc(100vw-2rem))]" aria-label="Přepínač barevného tématu">
  <label class="form-control border border-base-300 bg-base-100/92 p-3 shadow-2xl backdrop-blur">
    <span class="label pb-2 pt-0">
      <span class="label-text text-xs font-bold uppercase tracking-[0.16em] text-primary">Téma</span>
    </span>
    <select class="select select-bordered select-sm" data-theme-switcher aria-label="Vybrat téma webu">
      {site.themeOptions.map((theme) => (
        <option value={theme.name} selected={theme.name === site.theme}>{theme.label}</option>
      ))}
    </select>
  </label>
</aside>